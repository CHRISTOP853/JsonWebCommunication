             Margin="8,0,0,0"
             VerticalContentAlignment="Center"/> -->

    <!-- <ComboBox x:Name="cmbAddType"
              Width="120"
              Height="28"
              Margin="8,0,0,0">
        <ComboBoxItem Content="String"/>
        <ComboBoxItem Content="Number"/>
        <ComboBoxItem Content="Boolean"/>
        <ComboBoxItem Content="Null"/>
        <ComboBoxItem Content="Object"/>
        <ComboBoxItem Content="Array"/>
    </ComboBox> -->

    <!-- <Button Content="Add"
            Width="80"
            Margin="8,0,0,0"
            Click="AddNode_Click"/>
</StackPanel>              -->

    <!-- =========================
         MIDDLE: TREE + OUTPUT + QUERY + ADD
         ========================= -->
    <Grid Grid.Row="1" Margin="0,10,0,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Tree -->
        <GroupBox Header="JSON Tree" Grid.Column="0" Padding="8" Margin="0,0,10,0">
            <DockPanel>
                <TextBlock x:Name="lblSelected"
                           DockPanel.Dock="Bottom"
                           Margin="0,8,0,0"
                           Text="Selected: (none)"/>
                <TreeView x:Name="treeJson"
                          SelectedItemChanged="TreeJson_SelectedItemChanged"/>
            </DockPanel>
        </GroupBox>

        <!-- RIGHT: Output + Query + Add -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Output -->
            <GroupBox Header="Pretty Print / Output" Grid.Row="0" Padding="8">
                <TextBox x:Name="txtOutput"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"/>
            </GroupBox>

            <!-- Query -->
            <GroupBox Header="Query" Grid.Row="1" Padding="8" Margin="0,10,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtQuery"
                                 Height="28"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Example: team.name or players[0].stats.yards"/>
                        <Button Grid.Column="1"
                                x:Name="btnQuery"
                                Content="Run Query"
                                Margin="8,0,0,0"
                                Padding="12,4"
                                Click="RunQuery_Click"/>
                    </Grid>

                    <TextBox Grid.Row="1"
                             x:Name="txtQueryResult"
                             Margin="0,8,0,0"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Height="90"
                             TextWrapping="Wrap"
                             ToolTip="Query results appear here"/>
                </Grid>
            </GroupBox>

            <!-- Add / Generate -->
            <GroupBox Header="Generate / Add Node (to Selected)" Grid.Row="2" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Key:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtAddKey" Margin="0,0,0,8"
                             ToolTip="For object properties (ignored for array adds)"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Value:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtAddValue" Margin="0,0,0,8"
                             ToolTip="Value to add (for primitives)"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="Type:"/>
                    <Grid Grid.Row="2" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="cmbAddType" Height="28" SelectedIndex="0">
                            <ComboBoxItem Content="string"/>
                            <ComboBoxItem Content="number"/>
                            <ComboBoxItem Content="bool"/>
                            <ComboBoxItem Content="null"/>
                            <ComboBoxItem Content="object"/>
                            <ComboBoxItem Content="array"/>
                        </ComboBox>

                        <Button Grid.Column="1"
                                x:Name="btnAddNode"
                                Content="Add"
                                Margin="8,0,0,0"
                                Padding="12,4"
                                Click="AddNode_Click"/>
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- Status -->
            <StatusBar Grid.Row="3">
                <TextBlock x:Name="txtStatus" Text="Ready."/>
            </StatusBar>
        </Grid>
    </Grid>

    <!-- =========================
         BOTTOM: ACTIONS
         ========================= -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="btnPretty"
                Content="Pretty Print"
                Padding="12,6"
                Margin="0,0,10,0"
                Click="PrettyPrint_Click"/>
        <Button x:Name="btnSave"
                Content="Save Pretty JSON..."
                Padding="12,6"
                Margin="0,0,10,0"
                Click="Save_Click"/>
        <Button x:Name="btnClear"
                Content="Clear"
                Padding="12,6"
                Click="Clear_Click"/>
    </StackPanel>
</Grid>
</Window>