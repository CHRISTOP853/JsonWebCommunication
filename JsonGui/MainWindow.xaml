<Window x:Class="JsonGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Json Query Tool" Height="800" Width="1200" >
    <Grid Margin="12">
    <Grid.RowDefinitions>
       <RowDefinition Height="Auto"/> <!-- Source section -->
    <RowDefinition Height="*"/> <!-- TreeView -->
    <RowDefinition Height="Auto"/> <!-- Selected label -->
    <RowDefinition Height="Auto"/> <!-- Add node controls -->
    <RowDefinition Height="Auto"/> <!-- Bottom actions -->
    </Grid.RowDefinitions>

    <!-- =========================
         TOP: SOURCE (File/URL/Paste)
         ========================= -->
    <GroupBox Header="Source" Grid.Row="0" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton x:Name="rbFile" Content="From File" IsChecked="True" Margin="0,0,14,0"/>
                <RadioButton x:Name="rbUrl" Content="From URL" Margin="0,0,14,0"/>
                <RadioButton x:Name="rbPaste" Content="Paste JSON"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtSource"
                         Height="28"
                         VerticalContentAlignment="Center"
                         ToolTip="File path or URL (depending on selection)"/>

                <Button Grid.Column="1"
                        x:Name="btnBrowse"
                        Content="Browse..."
                        Margin="8,0,0,0"
                        Padding="12,4"
                        Click="Browse_Click"/>

                <Button Grid.Column="2"
                        x:Name="btnLoad"
                        Content="Load"
                        Margin="8,0,0,0"
                        Padding="12,4"
                        Click="Load_Click"/>

                <Button Grid.Column="3"
                        x:Name="btnParse"
                        Content="Parse"
                        Margin="8,0,0,0"
                        Padding="12,4"
                        Click="Parse_Click"/>
            </Grid>

            <TextBox Grid.Row="2"
                     x:Name="txtJson"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Height="150"
                     TextWrapping="Wrap"
                     ToolTip="Paste JSON here if 'Paste JSON' is selected."/>
        </Grid>
    </GroupBox>

